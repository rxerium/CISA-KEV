# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environments
env/
ENV/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Output files (keep the folders but ignore contents)
outputs/graphs/*.png
outputs/data/*.csv
outputs/data/*.json

# Keep the directory structure
!outputs/graphs/.gitkeep
!outputs/data/.gitkeep

# Temporary files
*.tmp

# Logs
logs/*.log
logs/poc-checkpoint.json

# Archive (test files)
archive/*

# Keep empty directories
!logs/.gitkeep
!archive/.gitkeep

# API Keys and Secrets (NEVER COMMIT THESE)
.env
.env.local
*.key
*_key.txt
**/vulncheck_api_key*
vulncheck_key*.txt
.secrets/

# Allow VulnCheck data files
!data/lists/VulnCheck*.txt
!data/raw/vulncheck*.json
!data/raw/vulncheck*.csv
